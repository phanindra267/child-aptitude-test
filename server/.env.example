# ==============================================================================
# AptitudePro Server - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Used for: test data, question banks, student responses
MONGODB_URI=mongodb://admin:password@localhost:27017/child_aptitude_test?authSource=admin

# --- PostgreSQL ---
# Used for: user accounts, analytics, structured relational data
POSTGRES_URI=postgresql://admin:password@localhost:5432/aptitudepro

# --- Redis ---
# Used for: session cache, rate limiting, Celery broker, pub/sub
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- External Services (optional) ---
# AWS S3 for backups and file storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=aptitudepro-backups

# --- Email (Celery email worker) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Monitoring ---
# Prometheus metrics endpoint (auto-exposed at /metrics)
ENABLE_METRICS=true
